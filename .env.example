# Neon Postgres connection string (pooled). Get it from the Neon console → Connect.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Signs admin session cookies — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Password for the seeded admin user (admin@goldenfork.dev), used by `npm run db:seed`
ADMIN_PASSWORD="admin123"

# Stripe — set both to enable online card payments at checkout
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# AI chat — set either to upgrade the support bot from rules to an LLM
AI_GATEWAY_API_KEY=""
OPENAI_API_KEY=""

# Public origin used for Stripe redirect URLs (defaults to request origin)
NEXT_PUBLIC_APP_URL=""
